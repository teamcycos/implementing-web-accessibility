{
  "name": "accessibility-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build:prod": "ng build --configuration production",
    "start": "ng serve",
    "start:prod": "ng serve --port 4201 --configuration production --live-reload=false",
    "start:lighthouse": "npm run build:prod && ws --spa index.html --port 4201 --directory ./dist/accessibility-app/browser",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --code-coverage --watch=false",
    "test:a11y": "playwright test tests/axe-core.spec.ts --project=chromium",
    "test:cypress": "start-server-and-test start:lighthouse http://localhost:4201 cypress:run:e2e:electron",
    "test:lighthouse-ci": "wait-on -t 300000 http://localhost:4201/ && lighthouse-ci --performance=0 --accessibility=90 --best-practices=0 --seo=0 --pwa=0 --report=html --output-path=dist/lighthouse-report.html http://localhost:4201/",
    "test:lighthouse-ci:prod": "concurrently \"npm:start:lighthouse\" \"npm:test:lighthouse-ci\" --kill-others --success=first",
    "cypress:open": "cypress open",
    "cypress:run:component": "wait-on -t 300000 http://localhost:4201/ && cypress run --browser chrome --headless --component",
    "cypress:run:e2e:chrome": "wait-on -t 300000 http://localhost:4201/ && cypress run --browser chrome --headless --e2e",
    "cypress:run:e2e:electron": "wait-on -t 300000 http://localhost:4201/ && cypress run --browser electron --headless --e2e",
    "lint:js": "ng lint",
    "lint:js:fix": "eslint --fix \"./src/**/*.{js,mjs,ts}\"",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "lighthouse-ci": "^1.13.1",
    "local-web-server": "^5.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.3",
    "@angular/cli": "~22.0.4",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@axe-core/playwright": "^4.12.1",
    "@cypress/schematic": "^5.0.0",
    "@cypress/webpack-preprocessor": "^7.1.1",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "accessibility-checker": "^4.0.16",
    "axe-core": "^4.12.1",
    "concurrently": "^9.2.3",
    "cypress": "^15.18.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^10.6.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-axe": "^1.1.0",
    "jasmine-core": "^6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "lighthouse": "^13.1.0",
    "playwright": "^1.61.0",
    "playwright-lighthouse": "^4.0.0",
    "angular-eslint": "^22.0.0",
    "start-server-and-test": "^3.0.11",
    "typescript-eslint": "^8.61.1",
    "typescript": "~6.0.3",
    "wait-on": "^9.0.4"
  }
}
